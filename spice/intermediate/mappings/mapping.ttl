  rr:logicalTable [ rr:tableName "src_drugbank.drugs_possiblediseasetarget__full" ] ;
  rr:subjectMap [ rr:template "http://www4.wiwiss.fu-berlin.de/drugbank/resource/drugs/{drugs}" ] ;
  rr:predicateObjectMap [ rr:predicate drugbank:possibleDiseaseTarget ; rr:objectMap [ rr:column "possiblediseasetarget" ; rr:termType rr:IRI ] ] .

<#LegacyDrugbankFoodInteraction>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "src_drugbank.drugs_foodinteraction__full" ] ;
  rr:subjectMap [ rr:template "http://www4.wiwiss.fu-berlin.de/drugbank/resource/drugs/{drugs}" ] ;
  rr:predicateObjectMap [ rr:predicate drugbank:foodInteraction ; rr:objectMap [ rr:column "foodinteraction" ] ] .

<#LegacyDrugbankDrugCategory>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "src_drugbank.drugs_drugcategory__full" ] ;
  rr:subjectMap [ rr:template "http://www4.wiwiss.fu-berlin.de/drugbank/resource/drugs/{drugs}" ] ;
  rr:predicateObjectMap [ rr:predicate drugbank:drugCategory ; rr:objectMap [ rr:column "drugcategory" ; rr:termType rr:IRI ] ] .

<#LegacyDrugbankDosageForm>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "src_drugbank.drugs_dosageform__full" ] ;
  rr:subjectMap [ rr:template "http://www4.wiwiss.fu-berlin.de/drugbank/resource/drugs/{drugs}" ] ;
  rr:predicateObjectMap [ rr:predicate drugbank:dosageForm ; rr:objectMap [ rr:column "dosageform" ] ] .

<#LegacyDrugbankDrugType>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "src_drugbank.drugs_drugtype__full" ] ;
  rr:subjectMap [ rr:template "http://www4.wiwiss.fu-berlin.de/drugbank/resource/drugs/{drugs}" ] ;
  rr:predicateObjectMap [ rr:predicate drugbank:drugType ; rr:objectMap [ rr:template "http://www4.wiwiss.fu-berlin.de/drugbank/resource/drugtype/{drugtype}" ; rr:termType rr:IRI ] ] .

<#LegacyDiseasomeMain>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "src_diseasome.diseases_main__full" ] ;
  rr:subjectMap [ rr:template "http://www4.wiwiss.fu-berlin.de/diseasome/resource/diseases/{diseases}" ; rr:class diseasome:diseases ] ;
  rr:predicateObjectMap [ rr:predicate diseasome:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate rdfs:label ; rr:objectMap [ rr:column "label" ] ] .

<#LegacyDiseasomePossibleDrug>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "src_diseasome.diseases_possibledrug__full" ] ;
  rr:subjectMap [ rr:template "http://www4.wiwiss.fu-berlin.de/diseasome/resource/diseases/{diseases}" ] ;
  rr:predicateObjectMap [ rr:predicate diseasome:possibleDrug ; rr:objectMap [ rr:column "possibledrug" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate drugbank:possibleDiseaseTarget ; rr:objectMap [ rr:column "possibledrug" ; rr:termType rr:IRI ] ] .

<#LegacyKeggDrugCore>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "src_kegg.drug_main__full" ] ;
  rr:subjectMap [ rr:template "http://bio2rdf.org/drug:{drug}" ; rr:class kegg:Drug ] ;
  rr:predicateObjectMap [ rr:predicate dce:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate bio2rdf:mass ; rr:objectMap [ rr:column "mass" ] ] .

<#LegacyKeggCompoundCore>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "src_kegg.compound_main__full" ] ;
  rr:subjectMap [ rr:template "http://bio2rdf.org/cpd:{compound}" ] ;
  rr:predicateObjectMap [ rr:predicate dce:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate bio2rdf:mass ; rr:objectMap [ rr:column "mass" ] ] .

<#LegacyKeggDrugXref>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:sqlQuery "SELECT dx.drug, CASE WHEN dx.xref LIKE 'http://bio2rdf.org/cas:%' THEN REPLACE(dx.xref, 'http://bio2rdf.org/cas:', '') ELSE dx.xref END AS xref FROM src_kegg.drug_xref__full dx"
  ] ;
  rr:subjectMap [ rr:template "http://bio2rdf.org/drug:{drug}" ] ;
  rr:predicateObjectMap [ rr:predicate bio2rdf:xRef ; rr:objectMap [ rr:column "xref" ] ] .

<#LegacyKeggEnzymeXSubstrate>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:sqlQuery "SELECT enzyme, CASE WHEN xsubstrate LIKE 'http://bio2rdf.org/cpd:%' THEN REPLACE(xsubstrate, 'http://bio2rdf.org/cpd:', '') ELSE xsubstrate END AS xsubstrate FROM src_kegg.enzyme_xsubstrate__full"
  ] ;
  rr:subjectMap [ rr:template "http://bio2rdf.org/ec:{enzyme}" ] ;
  rr:predicateObjectMap [ rr:predicate kegg:xSubstrate ; rr:objectMap [ rr:column "xsubstrate" ] ] .

<#LegacyKeggReactionXEnzyme>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "src_kegg.reaction_xenzyme__full" ] ;
  rr:subjectMap [ rr:template "http://bio2rdf.org/rn:{reaction}" ] ;
  rr:predicateObjectMap [ rr:predicate kegg:xEnzyme ; rr:objectMap [ rr:template "http://bio2rdf.org/ec:{xenzyme}" ; rr:termType rr:IRI ] ] .

<#LegacyKeggReactionMain>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "src_kegg.reaction_main__full" ] ;
  rr:subjectMap [ rr:template "http://bio2rdf.org/rn:{reaction}" ] ;
  rr:predicateObjectMap [ rr:predicate kegg:equation ; rr:objectMap [ rr:column "equation" ] ] ;
  rr:predicateObjectMap [ rr:predicate dce:title ; rr:objectMap [ rr:column "title" ] ] .

<#LegacyDailymedMain>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "src_dailymed.drugs_main__full" ] ;
  rr:subjectMap [ rr:template "http://www4.wiwiss.fu-berlin.de/dailymed/resource/drugs/{drugs}" ] ;
  rr:predicateObjectMap [ rr:predicate dailymed:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate dailymed:activeIngredient ; rr:objectMap [ rr:column "activeingredient" ] ] ;
  rr:predicateObjectMap [ rr:predicate dailymed:genericMedicine ; rr:objectMap [ rr:column "genericmedicine" ] ] ;
  rr:predicateObjectMap [ rr:predicate dailymed:representedOrganization ; rr:objectMap [ rr:column "representedorganization" ] ] ;
  rr:predicateObjectMap [ rr:predicate dailymed:routeOfAdministration ; rr:objectMap [ rr:column "routeofadministration" ] ] ;
  rr:predicateObjectMap [ rr:predicate dailymed:dosage ; rr:objectMap [ rr:column "dosage" ] ] ;
  rr:predicateObjectMap [ rr:predicate dailymed:description ; rr:objectMap [ rr:column "description" ] ] .

<#LegacyDailymedMainLowerName>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery "SELECT drugs, LOWER(name) AS name_lc FROM src_dailymed.drugs_main__full" ] ;
  rr:subjectMap [ rr:template "http://www4.wiwiss.fu-berlin.de/dailymed/resource/drugs/{drugs}" ] ;
  rr:predicateObjectMap [ rr:predicate dailymed:name ; rr:objectMap [ rr:column "name_lc" ] ] .

<#LegacyDailymedSodiumPhosphatesAlias>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery "SELECT drugs FROM src_dailymed.drugs_main__full WHERE LOWER(name) = 'sodium phosphates'" ] ;
  rr:subjectMap [ rr:template "http://www4.wiwiss.fu-berlin.de/dailymed/resource/drugs/{drugs}" ] ;
  rr:predicateObjectMap [ rr:predicate dailymed:name ; rr:objectMap [ rr:constant "Sodium phosphates" ] ] .

<#LegacyDailymedSameAs>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "src_dailymed.drugs_sameas__full" ] ;
  rr:subjectMap [ rr:template "http://www4.wiwiss.fu-berlin.de/dailymed/resource/drugs/{drugs}" ] ;
  rr:predicateObjectMap [ rr:predicate owl:sameAs ; rr:objectMap [ rr:column "sameas" ; rr:termType rr:IRI ] ] .

<#LegacyDailymedGenericDrugDbId>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery "SELECT drugs, genericdrug FROM src_dailymed.drugs_main__full WHERE genericdrug LIKE 'DB%'" ] ;
  rr:subjectMap [ rr:template "http://www4.wiwiss.fu-berlin.de/dailymed/resource/drugs/{drugs}" ] ;
