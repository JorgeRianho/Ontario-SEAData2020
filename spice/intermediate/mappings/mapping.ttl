<#LegacyAffymetrixXSymbolUpperAlias>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:sqlQuery "SELECT probeset, CASE WHEN x_symbol LIKE 'http://bio2rdf.org/symbol:%' THEN UPPER(REPLACE(x_symbol, 'http://bio2rdf.org/symbol:', '')) ELSE UPPER(x_symbol) END AS symbol_upper FROM src_affymetrix.probeset_x_symbol__full"
  ] ;
  rr:subjectMap [ rr:template "http://bio2rdf.org/probeset:{probeset}" ] ;
  rr:predicateObjectMap [ rr:predicate affymetrix:x-symbol ; rr:objectMap [ rr:template "http://bio2rdf.org/symbol:{symbol_upper}" ; rr:termType rr:IRI ] ] .

